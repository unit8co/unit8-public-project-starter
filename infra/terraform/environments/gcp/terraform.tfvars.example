project_id        = "my-gcp-project"
application_name  = "agentic-starter"
environment       = "dev"
region            = "europe-west1"
container_image   = "ghcr.io/unit8co/agentic-project-starter:latest"

env_vars = {
  APP_ENVIRONMENT = "gcp"
  LOG_LEVEL       = "INFO"
}

secret_names = ["openai-api-key"]
